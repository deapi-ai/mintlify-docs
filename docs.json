{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "deAPI",
  "logo": {
    "light": "/logo/deapi-light.svg",
    "dark": "/logo/deapi-dark.svg"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#FD9A00",
    "light": "#FFAD33",
    "dark": "#E58A00"
  },
  "api": {
    "openapi": [
      "openapi.json",
      "openapi-v2.json"
    ],
    "baseUrl": "https://api.deapi.ai",
    "auth": {
      "method": "bearer"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.deapi.ai/dashboard"
      },
      {
        "label": "Status",
        "href": "https://status.deapi.ai/"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/deapi-ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.deapi.ai/dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/deapi-ai",
      "twitter": "https://x.com/deAPI_",
      "discord": "https://discord.com/invite/UFfK5YRBsr"
    }
  },
  "search": {
    "prompt": "Search deAPI docs..."
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "models",
              "pricing",
              "architecture-and-security",
              "limits-and-quotas"
            ]
          },
          {
